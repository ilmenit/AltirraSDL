  "comments": {
    "$a000": "Cold start: disable NMI, IRQ, GRACTL, DMACTL; zero all HW regs",
    "$a04e": "Zero-fill RAM $00 through $3FFF",
    "$a05d": "Copy display list template from dl_template_data to $3F00",
    "$a06a": "Detect PAL/NTSC from $D014 bit 3; store in pal_flag",
    "$a15d": "State 3: begin new game \u2014 clear vars, init lives/score/fuel",
    "$a197": "Attract: wait for VCOUNT >= $78 (bottom of screen)",
    "$a1ae": "Read CONSOL: bit0=START, bit1=SELECT, bit2=OPTION",
    "$a271": "Entity update loop: iterate 6 slots, dispatch by type",
    "$a4e0": "Entity hit: set destruction anim, compute BCD score",
    "$a547": "SED/ADC score update \u2014 BCD addition from score_value_table",
    "$a5b7": "Advance terrain PRNG, compute new river bank positions",
    "$a688": "Player death: state=2, explosion timer, sound",
    "$a701": "Main loop: fuel management, back to frame sync",
    "$ae94": "DEC fuel_drain_ctr; JMP main_loop_continue",
    "$ae99": "=== MAIN FRAME SYNC === wait for VCOUNT < $50",
    "$aea0": "JSR frame_update \u2014 prepare display for next frame",
    "$afd0": "Frame update: scroll terrain, copy new row data to screen",
    "$aff4": "Fill terrain row: write pattern $55 to mode-14 bitmap line",
    "$b00f": "Blit Y+1 bytes from (src_ptr) to (dst_ptr)",
    "$b04b": "dst_ptr += 48 (one ANTIC mode 14 row pitch)",
    "$b07c": "Process collision flags set by DLI kernel",
    "$b0c7": "Find empty entity slot, select type, init position/shape",
    "$b0d8": "Per-entity movement: stationary / oscillate / track player",
    "$b183": "Redraw fuel gauge bars in status screen RAM",
    "$b298": "Read CONSOL switches, return decoded START/SELECT/OPTION",
    "$b2a5": "=== VBI HANDLER === sound engine: explosion, engine hum, silence",
    "$b3d8": "VBI continuation: game timers, color animation",
    "$b500": "=== DLI HANDLER === save regs, branch by VCOUNT",
    "$b510": "DLI playfield: init sprite masks, set missile positions",
    "$b567": "DLI WSYNC loop: per-scanline entity positioning (hottest code)",
    "$b72a": "DLI status bar: colors for score/fuel display area",
    "$b750": "DLI: position player sprites, clear collision regs",
    "$b773": "JMP XITVBV \u2014 return from interrupt",
    "$b776": "Display list template (copied to $3F00 at cold start)",
    "$b800": "Sprite shape data: entity graphics, 1024 bytes",
    "$bb0b": "BCD score values indexed by entity type",
    "$bc00": "Terrain bank shape templates (768 bytes)",
    "$bffa": "Vector table: cold=$A000, warm=$8000, IRQ=$A000"
