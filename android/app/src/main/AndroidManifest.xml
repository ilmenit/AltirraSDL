<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Storage access for ROM files and disk images.
         On Android 11+ (API 30+) scoped storage prevents apps from
         reading arbitrary files in /sdcard/Download, even with
         READ_EXTERNAL_STORAGE.  An emulator legitimately needs to
         pick user-supplied ROM / disk image / cassette files from
         anywhere the user puts them, so we request the broader
         MANAGE_EXTERNAL_STORAGE permission.  This is a "special"
         permission — the user must explicitly enable it from the
         system Settings app; the app shows a guided prompt the
         first time the file browser runs into a permission-denied
         folder. -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />
    <!-- Android 13+ granular media permissions (images covers ROM files) -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <!-- Haptic feedback -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Netplay lobby and peer connections.  Without INTERNET, Android
         denies socket(AF_INET, SOCK_STREAM, ...) with EPERM and the
         lobby reports "socket() failed". -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- OpenGL ES 3.0 required (maps to our GL 3.3 core backend) -->
    <uses-feature android:glEsVersion="0x00030000" android:required="true" />

    <!-- Touch screen (obviously required for mobile UI) -->
    <uses-feature android:name="android.hardware.touchscreen" android:required="true" />

    <!-- Gamepad support (optional — works via SDL3 gamepad API) -->
    <uses-feature android:name="android.hardware.gamepad" android:required="false" />

    <application
        android:label="Altirra"
        android:icon="@mipmap/ic_launcher"
        android:theme="@android:style/Theme.NoTitleBar.Fullscreen"
        android:hasCode="true"
        android:hardwareAccelerated="true"
        android:allowBackup="true"
        android:requestLegacyExternalStorage="true">

        <!-- Main activity — SDL3 provides SDLActivity which handles
             the GL surface, lifecycle, and native library loading.
             Our AltirraActivity extends it for any Android-specific
             customization (permissions, file picker intents). -->
        <activity
            android:name="org.altirra.app.AltirraActivity"
            android:configChanges="keyboard|keyboardHidden|orientation|screenSize|screenLayout|uiMode|locale|layoutDirection"
            android:screenOrientation="fullSensor"
            android:exported="true"
            android:launchMode="singleTask">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Handle Atari file types -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="*/*" />
                <data android:pathPattern=".*\\.xex" />
                <data android:pathPattern=".*\\.atr" />
                <data android:pathPattern=".*\\.car" />
                <data android:pathPattern=".*\\.cas" />
                <data android:pathPattern=".*\\.rom" />
            </intent-filter>

            <!-- SDL3 metadata: tell SDL which native library to load -->
            <meta-data android:name="SDL_MAIN_ENTRY_POINT"
                android:value="main" />
        </activity>
    </application>
</manifest>
