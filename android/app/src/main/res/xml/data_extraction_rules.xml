<?xml version="1.0" encoding="utf-8"?>
<!--
    Android backup / device-transfer rules (API 31+ — dataExtractionRules).
    Companion file res/xml/backup_rules.xml is the legacy equivalent for
    API <= 30 and must list the same exclusions.

    <cloud-backup>    — controls Google Drive Auto Backup snapshots
                        (the user's daily 24h sync, restored on app
                        reinstall and on new-device setup).
    <device-transfer> — controls D2D (device-to-device) migration via
                        Android Setup Wizard's "transfer from old
                        phone" flow.

    See backup_rules.xml for the rationale behind each exclusion.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="Altirra/AltirraSDL/imgui.ini"/>
        <exclude domain="file" path="Altirra/AltirraSDL/last_crash.txt"/>
        <exclude domain="file" path="Altirra/AltirraSDL/lobby.ini"/>
        <exclude domain="file" path="Altirra/AltirraSDL/netplay_cache/"/>
        <exclude domain="file" path="Altirra/AltirraSDL/thumbnails/"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="Altirra/AltirraSDL/imgui.ini"/>
        <exclude domain="file" path="Altirra/AltirraSDL/last_crash.txt"/>
        <exclude domain="file" path="Altirra/AltirraSDL/lobby.ini"/>
        <exclude domain="file" path="Altirra/AltirraSDL/netplay_cache/"/>
        <exclude domain="file" path="Altirra/AltirraSDL/thumbnails/"/>
    </device-transfer>
</data-extraction-rules>
